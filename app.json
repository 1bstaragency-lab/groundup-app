{
  "expo": {
    "name": "GrounduP",
    "slug": "groundup",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "groundup",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.groundupapp.ios",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "GrounduP does not use your camera.",
        "NSMicrophoneUsageDescription": "GrounduP does not use your microphone.",
        "NSPhotoLibraryUsageDescription": "GrounduP does not access your photos.",
        "NSUserTrackingUsageDescription": "GrounduP does not track you across apps.",
        "UIBackgroundModes": []
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0A"
      },
      "package": "com.groundupapp.android",
      "versionCode": 1,
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.0"
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "groundup-ios"
      }
    }
  }
}
